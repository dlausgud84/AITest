<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dit.site.persistence.mapper.SiteMapper">

    <!-- ════════════════════════════
         사이트 목록 조회 (NB_SITES)
         콤보박스용 SITE_ID, SITE_NAME 만 조회
         ════════════════════════════ -->
    <select id="selectSiteList" resultType="com.dit.site.dto.SiteDto">
        SELECT
            SITE_ID   AS siteId,
            SITE_NAME AS siteName
        FROM NB_SITES
        ORDER BY SITE_ID ASC
    </select>

</mapper>
