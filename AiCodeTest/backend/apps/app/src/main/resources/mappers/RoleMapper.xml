<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dit.role.persistence.mapper.RoleMapper">

    <!-- ════════════════════════════
         사이트 권한 목록 조회 (NB_ROLES)
         - SITE_ID 기준 필터
         - SYSTEM_ROLE_FLAG != 'Y' (시스템 전용 권한 제외)
         ════════════════════════════ -->
    <select id="selectRoleList" resultType="com.dit.role.dto.RoleDto">
        SELECT
            SITE_ID   AS siteId,
            ROLE_ID   AS roleId,
            ROLE_NAME AS roleName
        FROM NB_ROLES WITH (NOLOCK)
        WHERE 1 = 1
        <if test="siteId != null and siteId != ''">
            AND SITE_ID = #{siteId}
        </if>
            AND (SYSTEM_ROLE_FLAG IS NULL OR SYSTEM_ROLE_FLAG != 'Y')
        ORDER BY ROLE_ID ASC
    </select>

</mapper>
