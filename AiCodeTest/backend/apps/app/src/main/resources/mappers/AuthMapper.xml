<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dit.auth.persistence.mapper.AuthMapper">

    <resultMap id="siteMap" type="com.dit.auth.domain.Site">
        <result column="SITE_ID"   property="siteId" />
        <result column="SITE_NAME" property="siteName" />
    </resultMap>

    <resultMap id="userMap" type="com.dit.auth.domain.User">
        <result column="USER_ID"   property="userId" />
        <result column="USER_NAME" property="userName" />
        <result column="PASSWORD"  property="password" />
    </resultMap>

    <!-- MES 공장 목록 조회 -->
    <select id="selectMesSites" resultMap="siteMap">
        SELECT SITE_ID, SITE_NAME
        FROM NB_SITES
        WHERE SITE_TYPE = '00'
        ORDER BY SITE_NAME ASC
    </select>

    <!-- 사용자 ID로 사용자 조회 (비밀번호 검증은 Service에서 평문 비교로 수행) -->
    <select id="selectUserById" resultMap="userMap">
        SELECT USER_ID, USER_NAME, PASSWORD
        FROM NB_USERS
        WHERE USER_ID = #{userId}
          AND (DELETE_FLAG IS NULL OR DELETE_FLAG != 'Y')
    </select>

</mapper>
