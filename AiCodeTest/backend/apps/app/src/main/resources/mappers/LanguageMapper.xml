<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dit.language.persistence.mapper.LanguageMapper">

    <!-- ════════════════════════════
         언어 목록 조회 (NB_LANGUAGES)
         팝업용 LANGUAGE_ID, LANGUAGE_NAME 만 조회
         IS_ENABLE_FLAG = 'Y' 인 항목만 표시
         ════════════════════════════ -->
    <select id="selectLanguageList" resultType="com.dit.language.dto.LanguageDto">
        SELECT
            LANGUAGE_ID   AS languageId,
            LANGUAGE_NAME AS languageName
        FROM NB_LANGUAGES
        WHERE IS_ENABLE_FLAG = 'Y'
        ORDER BY LANGUAGE_ID ASC
    </select>

</mapper>
